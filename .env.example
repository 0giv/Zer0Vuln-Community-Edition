# Zer0Vuln Community Edition — environment template
# Copy to .env and replace every <PLACEHOLDER> before booting the stack.



# ─── Database ────────────────────────────────────────────────────────────
DB_HOST=db
DB_PORT=3306
DB_USER=root
DB_PASSWORD=<CHANGE-ME-strong-mysql-password>

# ─── Ingestion ───────────────────────────────────────────────────────────
INGEST_BIND=0.0.0.0
INGEST_PORT=5001

# ─── Agent auth shared secret ────────────────────────────────────────────
# Used as the X-Agent-Key fallback when the operator hasn't enrolled a
# per-agent key. Auto-generated on first boot if unset; set it here to
# keep the same value across container restarts.
# AGENT_SHARED_SECRET=

# ─── Local AI (Ollama) ───────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434/api
OLLAMA_MODEL=llama3.2:3b
# AI_AUTO_ACT_CONF=0.75   # confidence floor for autonomous SOAR actions

# ─── Frontend ────────────────────────────────────────────────────────────
CORS_ORIGINS=*
VITE_API_BASE_URL=http://localhost:8000

# ─── OpenSearch ──────────────────────────────────────────────────────────
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=<CHANGE-ME>

# ─── Threat Intel (optional, no-op when empty) ───────────────────────────
# OTX_API_KEY=
# VT_API_KEY=

# ─── Vulnerability Scanner (OSV) ─────────────────────────────────────────
# auto   - probe public OSV at boot; fall back to mirror if unreachable
# online - always use the public OSV API
# mirror - always use OSV_MIRROR_URL (fail-closed if unset)
OSV_MODE=auto
OSV_PUBLIC_URL=https://api.osv.dev
# OSV_MIRROR_URL=http://osv-mirror.internal:8080
VULN_SCAN_INTERVAL=1800

# ─── Local Fernet key path (community edition) ───────────────────────────
# FERNET_KEY_PATH=/app/data/fernet.key
